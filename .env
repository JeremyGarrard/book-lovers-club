# Copy to .env and fill in values before running locally
DATABASE_URL=sqlite:///./booklovers.db
SECRET_KEY=changeme-use-a-long-random-string

# Admin seed (optional — first registered user auto-becomes admin)
ADMIN_USERNAME=
ADMIN_PASSWORD=

# Google OAuth (optional — leave blank to disable)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
BASE_URL=http://localhost:8000

# Mailchimp (optional — leave blank to gracefully skip)
MAILCHIMP_API_KEY=
MAILCHIMP_LIST_ID=
MAILCHIMP_SERVER_PREFIX=us1

# Custom Ink merch URL (optional — shows "coming soon" if blank)
CUSTOM_INK_URL=
